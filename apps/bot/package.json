{
  "name": "@discord-bot/bot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "commands:register": "tsx src/register-commands.ts",
    "dev": "tsx src/index.ts",
    "lint": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/index.js",
    "test": "tsc -p tsconfig.json && node --test dist/discord/components-v2.test.js dist/discord/message-logs.test.js dist/discord/temp-voice.test.js dist/discord/voice-state.test.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@discord-bot/config": "workspace:*",
    "@discord-bot/db": "workspace:*",
    "@discord-bot/discord-core": "workspace:*",
    "@discord-bot/logger": "workspace:*",
    "@discord-bot/redis": "workspace:*",
    "@discord-bot/shared": "workspace:*",
    "discord.js": "*"
  },
  "devDependencies": {
    "tsx": "*",
    "typescript": "*"
  }
}
