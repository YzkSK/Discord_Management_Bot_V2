{
  "name": "discord-bot",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.24.0",
  "engines": {
    "node": ">=24 <25",
    "pnpm": ">=10"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "db:generate": "pnpm --filter @discord-bot/db db:generate",
    "db:migrate": "pnpm --filter @discord-bot/db db:migrate"
  },
  "devDependencies": {
    "@types/node": "*",
    "turbo": "*",
    "typescript": "*"
  }
}
